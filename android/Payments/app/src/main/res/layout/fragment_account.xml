<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:padding="20dp" android:gravity="center_horizontal"
    android:background="?android:attr/colorBackground">

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="SIGN UP YOUR PAYMENT ACCOUNT" android:textAlignment="center"
        android:textColor="#7B61FF" android:textSize="20sp" android:textStyle="bold" />

    <ProgressBar style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="16dp" android:progress="25" android:progressTint="#7B61FF" />

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="20dp" android:text="Account Information:"
        android:textColor="#7B61FF" android:textSize="18sp" android:textStyle="bold"/>

    <EditText android:id="@+id/etEmail" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:hint="Email" android:inputType="textEmailAddress"
        android:drawablePadding="10dp" android:drawableStart="@android:drawable/ic_dialog_email"/>

    <EditText android:id="@+id/etUsername" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:hint="User Name"
        android:drawablePadding="10dp" android:drawableStart="@android:drawable/ic_menu_myplaces"/>

    <EditText
        android:id="@+id/etPassword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:drawableStart="@android:drawable/ic_secure"
        android:drawablePadding="10dp"
        android:hint="Password"
        android:inputType="textPassword"
        android:minHeight="48dp" />

    <EditText
        android:id="@+id/etConfirmPassword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:drawableStart="@android:drawable/checkbox_on_background"
        android:drawablePadding="10dp"
        android:hint="Confirm Password"
        android:inputType="textPassword"
        android:minHeight="48dp" />

    <Button android:id="@+id/btnNext1" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:layout_marginTop="20dp"
        android:backgroundTint="#7B61FF" android:text="Next" />

    <TextView
        android:id="@+id/tvViewRecords"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="View Records"
        android:textAlignment="center"
        android:textColor="#7B61FF"
        android:textSize="16sp"
        android:textStyle="bold" />
</LinearLayout>