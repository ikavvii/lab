<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:padding="20dp"
    android:background="?android:attr/colorBackground">

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Saved Database Records" android:textSize="22sp" android:textStyle="bold" android:textColor="#7B61FF"/>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent" android:layout_marginTop="20dp">
        <TextView android:id="@+id/tvDatabaseRecords" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textSize="16sp" android:lineSpacingExtra="5dp"/>
    </ScrollView>
</LinearLayout>